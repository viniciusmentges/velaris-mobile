{
  "expo": {
    "name": "Velaris",
    "slug": "velaris",
    "scheme": "velaris",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C14"
    },
    "ios": {
      "bundleIdentifier": "br.com.velarisapp",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSMotionUsageDescription": "O Velaris usa dados de movimento para calcular o desgaste dos seus tênis."
      }
    },
    "android": {
      "package": "br.com.velarisapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080C14"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4D9EFF"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "433e1ef0-0362-49bc-bd74-7808a3e3fa10"
      },
      "REVENUECAT_APPLE_KEY": "appl_SUBSTITUA_PELA_SUA_CHAVE",
      "REVENUECAT_GOOGLE_KEY": "goog_SUBSTITUA_PELA_SUA_CHAVE"
    },
    "updates": {
      "url": "https://u.expo.dev/433e1ef0-0362-49bc-bd74-7808a3e3fa10"
    }
  }
}
